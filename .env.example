# ─── NextAuth ────────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Database (Prisma / PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/prime_hub

# ─── Firebase Admin SDK (server-side only) ───────────────────────────────────
# Encontre no Google Cloud Console → IAM & Admin → Service Accounts
# Clique na service account → Manage Keys → Add Key → JSON
# Cole os valores abaixo do arquivo JSON baixado:
FIREBASE_PROJECT_ID=seu-project-id-aqui
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-project-id.iam.gserviceaccount.com
# IMPORTANTE: Cole a private_key completa entre aspas, mantendo os \n literais:
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"
